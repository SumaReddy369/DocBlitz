# AI Provider: "groq" (FREE), "gemini" (FREE), or "openai"
AI_PROVIDER=groq

# For Groq - FREE key at https://console.groq.com/keys
# Uses local embeddings (no API) + Groq for chat
GROQ_API_KEY=gsk_your_groq_api_key_here
# IMPORTANT: Delete old documents and re-upload after switching to Groq

# For Gemini (when limits reset)
GEMINI_API_KEY=your-gemini-api-key-here

# For OpenAI (paid)
OPENAI_API_KEY=sk-your-openai-api-key-here

# Optional - defaults shown
SECRET_KEY=your-super-secret-key-change-in-production
DATABASE_URL=postgresql://postgres:postgres@db:5432/docqa

# For deployment: add your frontend URL(s) for CORS (comma-separated)
# Example: CORS_ORIGINS=https://your-app.vercel.app,https://your-app.up.railway.app
